# Set these in your deployment platform's secret manager; do not commit .env.
DATABASE_URL=postgresql://pulsenet:change-me@127.0.0.1:5432/pulsenet
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Comma-separated HTTPS origins, e.g. https://portal.example.co.ke,https://admin.example.co.ke
# Include the Hotspot captive DNS name too (it's served over plain HTTP by
# RouterOS, e.g. http://login.pulsenet.test) or mikrotik-hotspot/hotspot/login.html's
# package-grid fetch() calls will be blocked by CORS.
CORS_ORIGINS=https://portal.example.co.ke,https://admin.example.co.ke,http://login.pulsenet.test
# M-PESA/Daraja and OTP gateway credentials belong in the deployment secret store.
# Do not enable customer login or mark an STK payment complete without verified callbacks.
#
# Safaricom Daraja (M-PESA). Get these from https://developer.safaricom.co.ke
# — use the Sandbox app credentials/shortcode/passkey while testing, and your
# Go-Live production app's credentials once approved for production.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Sandbox shortcode is 174379; use your assigned Paybill/Till in production.
MPESA_SHORTCODE=174379
# Sandbox passkey is published on the Daraja docs; production passkey comes from Safaricom.
MPESA_PASSKEY=
MPESA_ENVIRONMENT=production
# Must be a public HTTPS URL Safaricom can reach — e.g. https://api.example.co.ke/api/payments/mpesa/callback
# Daraja will not deliver callbacks to localhost or a private/self-signed URL.
MPESA_CALLBACK_URL=https://api.example.co.ke/api/payments/mpesa/callback

# Encrypts PPPoE/Hotspot subscriber passwords at rest (provisioning_mappings.pppoePasswordEncrypted).
# Generate with: openssl rand -base64 32
# Losing/rotating this key makes existing encrypted passwords unreadable —
# affected subscribers would need POST /subscriptions/:id/reset-password.
PROVISIONING_CREDENTIAL_KEY=

# First-run seed (supply the password through the deployment secret store only).
SEED_ADMIN_EMAIL=enoswebala27@gmail.com
SEED_ADMIN_PASSWORD=
SEED_CUSTOMER_PHONE=0743901680

# SMS gateway (customer OTP, activation/suspension/expiry notifications).
# Leave blank in development — the app runs fine with no SMS provider
# configured (see lib/sms/noop-provider.ts); messages just stay queued with
# a clear "not configured" reason instead of silently vanishing. A tenant
# can also configure their own Texin account from Settings > Notifications >
# SMS in the admin dashboard, which takes priority over these env vars.
SMS_PROVIDER=texin
TEXIN_API_URL=
TEXIN_API_KEY=
TEXIN_API_SECRET=
TEXIN_SENDER_ID=

# AI NOC (artifacts/api-server/src/services/noc-*.ts)
# Optional. Without this, the NOC still fully detects faults, anomalies,
# congestion, and correlates outages, and still recommends/executes safe
# actions — it just falls back to deterministic rule-based summaries instead
# of LLM-written root-cause narratives and incident reports.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-5 if unset.
ANTHROPIC_NOC_MODEL=

# Centralized RADIUS (AAA) — @workspace/radius-server, a separate long-running
# process from api-server (see artifacts/radius-server). Only needed once a
# tenant enables RADIUS for a NAS from Admin > RADIUS; PPPoE/Hotspot auth via
# the existing MikroTik provisioning flow works with none of this set.
# Uses the SAME DATABASE_URL and PROVISIONING_CREDENTIAL_KEY as api-server —
# it decrypts the identical router-side password and RADIUS-secret
# ciphertexts, so both processes must be given the exact same key.
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_BIND_HOST=0.0.0.0

